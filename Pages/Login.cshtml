@page
@using CRMService.Pages
@using Microsoft.AspNetCore.Mvc.ModelBinding
@model LoginModel
@{
    ViewData[index: "Title"] = "Вход";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light p-3">
    <div class="bg-white border rounded-3 shadow-sm p-4 w-100" style="max-width: 420px;">
        <h2 class="mb-4">Вход в приложение</h2>

        <form method="post" class="w-100" style="max-width: 400px;">
            @if (ViewData.ModelState.TryGetValue(string.Empty, out ModelStateEntry? modelErrorEntry) && modelErrorEntry.Errors.Count > 0)
            {
                <div class="alert alert-danger d-flex align-items-center justify-content-center text-center py-2 mb-3"
                     role="alert">
                    @modelErrorEntry.Errors[index: 0].ErrorMessage
                </div>
            }

            <div class="mb-3">
                <label for="Login" class="form-label">Логин</label>
                <input asp-for="UserPage.Login" id="Login" class="form-control" required />
                <span asp-validation-for="UserPage.Login" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label for="Password" class="form-label">Пароль</label>
                <input asp-for="UserPage.Password" type="password" id="Password" class="form-control" required />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Войти</button>
            </div>
        </form>

    </div>
</div>