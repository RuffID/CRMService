@page
@model CRMService.Pages.UsersModel
@{
    ViewData["Title"] = "Пользователи";
}

<div class="min-vh-100 bg-light p-3">
    <div id="pageError" class="alert alert-danger d-none mb-3"></div>
    <div id="pageSuccess" class="alert alert-success d-none mb-3"></div>

    <div class="bg-white border rounded-3 shadow-sm p-3">
        <div class="d-flex flex-wrap gap-3 justify-content-end align-items-center mb-3">
            <div class="form-check m-0">
                <input class="form-check-input" type="checkbox" id="showInactiveUsers" />
                <label class="form-check-label" for="showInactiveUsers">Показать удалённых</label>
            </div>
            <button type="button" class="btn btn-success" id="btnOpenCreateUser">Создать пользователя</button>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0" id="usersGrid">
                <thead class="table-light">
                    <tr>
                        <th>Имя</th>
                        <th>Логин</th>
                        <th>Роли</th>
                        <th class="text-center">Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody id="usersRows"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-title fw-semibold" id="userModalTitle">Новый пользователь</div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="userModalError" class="alert alert-danger d-none mb-3"></div>

                <input id="userId" type="hidden" />

                <div class="mb-3">
                    <label class="form-label" for="userName">Имя</label>
                    <input id="userName" class="form-control" maxlength="100" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="userLogin">Логин</label>
                    <input id="userLogin" class="form-control" maxlength="45" />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="userPassword">Пароль</label>
                    <input id="userPassword" type="password" class="form-control" maxlength="100" />
                    <div class="text-muted small mt-1" id="userPasswordHint">Обязателен для нового пользователя.</div>
                </div>

                <div>
                    <label class="form-label">Роли</label>
                    <div id="userRoles" class="border rounded-2 p-2" style="max-height: 180px; overflow-y: auto;"></div>
                    <div class="text-muted small mt-1">Выберите хотя бы одну роль.</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-primary" id="btnSaveUser">Создать</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/helpers/http.js" asp-append-version="true"></script>
<script src="~/js/helpers/verificationToken.js" asp-append-version="true"></script>
<script src="~/js/users/users.js" asp-append-version="true"></script>
